        <!--View Controller-->
        <scene sceneID="znp-hY-ufa">
            <objects>
                <viewController storyboardIdentifier="Urbanizacion" id="Nrm-Xe-Uhb" sceneMemberID="viewController">
                    <layoutGuides>
                        <viewControllerLayoutGuide type="top" id="SJI-bH-dJW"/>
                        <viewControllerLayoutGuide type="bottom" id="Gbb-3r-wqf"/>
                    </layoutGuides>
                    <view key="view" contentMode="scaleToFill" id="Op5-ew-Ds3">
                        <rect key="frame" x="0.0" y="0.0" width="768" height="1400"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Un Condominio Para Vivir Felices Por Siempre" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="bP1-KM-bEG">
                                <rect key="frame" x="30" y="30" width="447.5" height="25.5"/>
                                <fontDescription key="fontDescription" type="boldSystem" pointSize="21"/>
                                <color key="textColor" name="sectionColor_informacion"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="HzZ-XH-xwo">
                                <rect key="frame" x="30" y="62.5" width="708" height="117"/>
                                <string key="text">PRADOS DE SAN CRISTOBAL, un condominio construido en una zona residencial de rápido crecimiento y de gran plusvalía como lo es Pinares de San Cristóbal,  a tan sólo 5 minutos del bulevar principal, con rápido acceso a centros comerciales, bancos, supermercados, restaurantes, laboratorios, hospitales, colegios, gasolineras y centros automotrices entre muchos otros servicios. 

Construido en un área de 36 manzanas, Prados de San Cristóbal cuenta con incomparables ventajas entre las que cabe mencionar:</string>
                                <fontDescription key="fontDescription" type="system" pointSize="14"/>
                                <nil key="textColor"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="GSI-Tu-ues">
                                <rect key="frame" x="30" y="802.5" width="708" height="134"/>
                                <string key="text">Su comercialización, desarrollo y construcción está a cargo de Multiproyectos, la división inmobiliaria de Corporación Multi Inversiones, un consorcio multinacional integrado por más de 28,000 colaboradores con presencia en tres continentes, particularmente en Centroamérica y el Caribe desde hace casi más de noventa años, con una cultura corporativa fundamentada en la Responsabilidad, Honestidad, Respeto, Excelencia, Humildad, Lealtad y Amistad.  Actualmente tienen una participación independiente en 6 divisiones de negocios como son: la molinería, restaurantes de comida rápida, operaciones pecuarias, avícolas y porcinas, proyectos de generación de energía renovable, desarrollo de operaciones financieras y proyectos de construcción como PRADOS DE  SAN CRISTÓBAL.</string>
                                <fontDescription key="fontDescription" type="system" pointSize="14"/>
                                <nil key="textColor"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <stackView opaque="NO" contentMode="scaleToFill" axis="vertical" distribution="fillProportionally" spacing="15" translatesAutoresizingMaskIntoConstraints="NO" id="3Fe-ve-9rx">
                                <rect key="frame" x="30" y="194.5" width="708" height="465"/>
                                <subviews>
                                    <stackView opaque="NO" contentMode="scaleToFill" alignment="top" spacing="20" translatesAutoresizingMaskIntoConstraints="NO" id="qeK-GW-Wwz">
