                <viewController storyboardIdentifier="Historia" id="kTA-At-EpM" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="HEt-VR-BB0">
                        <rect key="frame" x="0.0" y="0.0" width="768" height="1024"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Historia de San Cristóbal" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="vMl-Kz-FiF">
                                <rect key="frame" x="30" y="30" width="244" height="25.5"/>
                                <fontDescription key="fontDescription" type="boldSystem" pointSize="21"/>
                                <color key="textColor" name="sectionColor_sanCristobal"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleToFill" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="sanCristobal" translatesAutoresizingMaskIntoConstraints="NO" id="A2G-T9-wjs">
                                <rect key="frame" x="30" y="65.5" width="708" height="150"/>
                                <constraints>
                                    <constraint firstAttribute="height" constant="150" id="aRJ-JK-LIb"/>
                                </constraints>
                                <userDefinedRuntimeAttributes>
                                    <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                                        <integer key="value" value="6"/>
                                    </userDefinedRuntimeAttribute>
                                </userDefinedRuntimeAttributes>
                            </imageView>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="cdZ-jZ-Iq1">
                                <rect key="frame" x="30" y="225.5" width="708" height="167.5"/>
                                <mutableString key="text">Ciudad San Cristóbal es un barrio  en la ciudad de Mixco, y parte del departamento de Guatemala. Uno de los acontecimientos más grandes de vivienda cerca de la ciudad de Guatemala, se desarrolló por primera vez por DEINCO, una importante empresa inmobiliaria, en 1973. Se extiende por más de 10 kilómetros cuadrados, separada de la capital por un cañón, lo que ha hecho que antes era muy difícil de desarrollar. DEINCO construyó un puente, llamado Puente de San Cristóbal, para que las personas puedan llegar fácilmente a los nuevos desarrollos de la ciudad. Al principio sólo dos carriles, el puente tuvo que ser posteriormente ampliado a cuatro carriles para dar cabida a la enorme cantidad de tráfico que va y viene de la ciudad.  Según la encuesta de población de 2002 por el Instituto Nacional de Estadística, todo el municipio de Mixco es el hogar de más de 400.000 personas. De estos, al menos 150.000 viven en Ciudad San Cristóbal.</mutableString>
                                <fontDescription key="fontDescription" type="system" pointSize="14"/>
                                <nil key="textColor"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Ciudad San Cristóbal" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="2hd-3h-OKG">
                                <rect key="frame" x="30" y="423" width="208" height="25.5"/>
                                <fontDescription key="fontDescription" type="boldSystem" pointSize="21"/>
                                <color key="textColor" name="sectionColor_sanCristobal"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="Oqe-9A-WeK">
                                <rect key="frame" x="30" y="455.5" width="708" height="84"/>
                                <mutableString key="text">San Cristóbal debido a su diversidad de servicios, y a su importante aporte a la economía y desarrollo del país, se ha convertido en una cuidad, en la que encontramos toda clase de servicios.  A continuación generalidades de los comercios y servicios con los que cuenta esta parte importante de la zona 8 de Mixco:</mutableString>
                                <fontDescription key="fontDescription" type="system" pointSize="14"/>
                                <nil key="textColor"/>
                                <nil key="highlightedColor"/>
                            </label>
